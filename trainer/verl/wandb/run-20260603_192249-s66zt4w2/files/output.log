    def __init__(self, conv_channels, embed_dim):
        super(AttentionLayerNew, self).__init__()
        self.in_projection = Linear(conv_channels, embed_dim)
        self.out_projection = Linear(embed_dim, conv_channels)
        self.bmm = torch.bmm

